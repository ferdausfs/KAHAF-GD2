<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="?attr/colorSurface">

    <!-- ═══ Phase 1: Countdown ═══ -->
    <LinearLayout
        android:id="@+id/group_countdown"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⏳"
            android:textSize="64sp"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Please Wait"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tv_countdown_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="A brief delay is required before access is granted"
            android:textSize="14sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:gravity="center"
            android:layout_marginBottom="40dp" />

        <TextView
            android:id="@+id/tv_countdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="30"
            android:textSize="72sp"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary"
            android:layout_marginBottom="24dp" />

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progress_countdown"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:progress="100"
            app:trackCornerRadius="4dp" />

    </LinearLayout>

    <!-- ═══ Phase 2: PIN Entry ═══ -->
    <LinearLayout
        android:id="@+id/group_pin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔐"
            android:textSize="56sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Enter PIN to Continue"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"
            android:layout_marginBottom="32dp" />

        <!-- PIN dots display -->
        <LinearLayout
            android:id="@+id/pin_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="12dp">

            <View android:id="@+id/dot1" style="@style/PinDot" />
            <View android:id="@+id/dot2" style="@style/PinDot" />
            <View android:id="@+id/dot3" style="@style/PinDot" />
            <View android:id="@+id/dot4" style="@style/PinDot" />
            <View android:id="@+id/dot5" style="@style/PinDot" />
            <View android:id="@+id/dot6" style="@style/PinDot" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_pin_error"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="13sp"
            android:textColor="@color/error"
            android:gravity="center"
            android:layout_marginBottom="24dp"
            android:visibility="gone" />

        <!-- Numpad -->
        <include android:id="@+id/numpad" layout="@layout/layout_numpad" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_pin_confirm"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="16dp"
            android:text="Unlock"
            android:textSize="16sp" />
    </LinearLayout>

</LinearLayout>
