<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvServiceStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Checking..."
        android:textSize="16sp"
        android:textStyle="bold"
        android:padding="8dp" />

    <TextView
        android:id="@+id/tvModelStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⚠️ কোনো AI Model নেই — Image analysis বন্ধ"
        android:textSize="14sp"
        android:padding="8dp"
        android:layout_marginBottom="4dp" />

    <Button
        android:id="@+id/btnEnableService"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Service চালু করুন"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tvKeywordCount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="0 keywords"
        android:textSize="14sp"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnAddKeyword"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="+ Keyword"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btnAddModel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="+ AI Model"
            android:layout_marginStart="4dp" />

        <Button
            android:id="@+id/btnClearAll"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Clear All"
            android:layout_marginStart="4dp" />

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvKeywords"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp" />

</LinearLayout>
