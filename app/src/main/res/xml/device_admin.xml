<?xml version="1.0" encoding="utf-8"?>
<!--
  Device Admin capabilities.
  The app MUST be active Device Admin before it can be uninstalled.
  User must go: Settings > Security > Device Admin Apps > BulldogBlocker > Deactivate
  Only THEN can they uninstall. This is enforced by Android OS.

  FIX: Removed unused high-risk policies (reset-password, wipe-data, disable-camera etc.)
  that aren't needed and cause unnecessary user concern during admin activation.
-->
<device-admin>
    <uses-policies>
        <lock-screen />
        <watch-login />
    </uses-policies>
</device-admin>
